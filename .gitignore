# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
e2e/.auth/
/test-results/
/playwright-report/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# mobile
/mobile

# uploaded files (dev + prod)
/public/uploads
/uploads

# content (blog articles + strategy — local only)
/content

# local-only docs (not for git)
*.local.md

# automation setup script (contains persona password hash — keep local)
scripts/setup-automation-personas.sql

# Aim Lab (sideway development — kept local only, do not ship to prod)
/src/app/(main)/aim
/src/components/aim

# internal planning docs (blueprint lives inside _docs)
/_docs/blueprint

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code / autonomous-company internals — local only, never in the product repo
.claude/agents/
.claude/commands/
.claude/company/
.claude/skills/
