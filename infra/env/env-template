# ============================================================
# GamerHub Environment Variables (VPS)  — CANONICAL deploy template
# Copy this to /var/www/gglobby/.env and fill in values.
# (Reconciled with .env.example, audit finding M6 — keep the two in sync.)
# ============================================================

# ── Database ─────────────────────────────────
DATABASE_URL=postgresql://gamerhub_app:YOUR_PASSWORD@localhost:5432/gamerhub

# ── Auth.js ──────────────────────────────────
NEXTAUTH_URL=https://gglobby.in
# AUTH_SECRET is the canonical name (Auth.js v5). REQUIRED — admin-token signing
# now fails closed without it. NEXTAUTH_SECRET is kept only as the socket-token
# fallback in server.mjs; set BOTH to the same value to be safe.
AUTH_SECRET=GENERATE_WITH_openssl_rand_base64_32
NEXTAUTH_SECRET=GENERATE_WITH_openssl_rand_base64_32

# ── Security / secrets ───────────────────────
# Admin PIN gate (bcrypt hash of the PIN), cron-route auth, token encryption.
ADMIN_PIN_HASH=
CRON_SECRET=GENERATE_WITH_openssl_rand_base64_32
TOKEN_ENCRYPTION_KEY=GENERATE_WITH_openssl_rand_base64_32

# ── Google OAuth ─────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── File Uploads ─────────────────────────────
UPLOAD_DIR=/var/www/gglobby/uploads

# ── App ──────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://gglobby.in
NEXT_PUBLIC_SITE_URL=https://gglobby.in
NODE_ENV=production
PORT=3000

# ── Discord Integration ─────────────────────
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=

# ── LiveKit (Voice/Video) ───────────────────
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
NEXT_PUBLIC_LIVEKIT_URL=

# ── Stripe (Payments) ───────────────────────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── OpenAI (AI Features) ────────────────────
OPENAI_API_KEY=

# ── Analytics ────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ── Pro Scene ingest (vlr.gg) ───────────────
# Base URL of a SELF-HOSTED vlrggapi instance (https://github.com/axsddlr/vlrggapi).
# Do NOT use the public Vercel instance (rate-limited/disabled). Run it on the VPS,
# e.g. on :3001, and point this at it. Used by infra/ingest/vlr-ingest.mjs (nightly).
VLRGG_API_BASE=
VLR_TIMESPAN=90

# ── Twitch Integration ──────────────────────
# Used by src/lib/services/integrations/twitch.ts (were missing from both templates).
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_WEBHOOK_SECRET=

# ── Valorant tracker (Riot / Henrik) ────────
# Live lookups are OFF by default (mocks). Enabling live requires BOTH flags AND
# RSO-gating to the caller's own account (Riot ToS — audit H9). Leave live off.
RIOT_API_KEY=
RIOT_CLIENT_ID=
RIOT_CLIENT_SECRET=
HENRIK_API_KEY=
TRACKER_USE_LIVE=false
TRACKER_RSO_COMPLIANT=false
STEAM_API_KEY=

# ── Email (Resend) ──────────────────────────
RESEND_API_KEY=
EMAIL_FROM=ggLobby <noreply@gglobby.in>
